{
    "name": "Paperclip + OpenClaw + Ollama (Local & Cloud)",
    "description": "Paperclip + OpenClaw + Ollama (Local & Cloud)",
    "version": "1.0.0",
    "author": "Akkappsoft",
    "license": "MIT",
    "files": [
        "docker/*",
        "data/*",
        ".env.tpl",
        "docker-compose.yml"
    ],
    "prompts": [
        {
            "name": "USER_TIMEZONE",
            "type": "text",
            "description": "User Timezone",
            "configKey": "timezone",
            "default": "Asia/Bangkok"
        },
        {
            "name": "OPENCLAW_GATEWAY_TOKEN",
            "type": "password",
            "description": "OpenClaw Gateway Token",
            "configKey": "openclaw.gateway_token"
        },
        {
            "name": "TAILSCALE_HOSTNAME",
            "type": "text",
            "description": "Tailscale Hostname",
            "configKey": "tailscale_hostname"
        },
        {
            "name": "BETTER_AUTH_SECRET",
            "type": "password",
            "description": "Better Auth Secret",
            "command": ""
        },
        {
            "name": "OLLAMA_MODEL",
            "type": "text",
            "description": "Ollama Model",
            "configKey": "llm.model"
        },
        {
            "name": "OLLAMA_PROVIDER",
            "type": "text",
            "description": "Ollama Provider",
            "configKey": "llm.provider"
        },
        {
            "name": "OLLAMA_BASE_URL",
            "type": "text",
            "description": "Ollama Base URL",
            "configKey": "llm.base_url"
        },
        {
            "name": "OLLAMA_API_KEY",
            "type": "password",
            "description": "Ollama API Key",
            "configKey": "llm.api_key"
        },
        {
            "name": "OLLAMA_MODELS",
            "type": "text",
            "description": "Ollama Models",
            "configKey": "llm.models"
        }
    ]
}